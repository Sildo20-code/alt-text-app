{
  "manifest_version": 3,
  "name": "Alt Text Generator for E-commerce",
  "version": "1.1.0",
  "description": "Generate Greek SEO-friendly alt text variations for ecommerce product pages with one click.",
  "homepage_url": "https://alt-text-q6lg8jonb-ersil.vercel.app",
  "minimum_chrome_version": "114",
  "permissions": ["activeTab", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Alt Text Generator",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
