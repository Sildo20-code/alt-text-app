{
  "manifest_version": 3,
  "name": "SEO Alt Text Assistant",
  "version": "1.2.0",
  "description": "Generate SEO-friendly Greek alt text variations for ecommerce product pages in one click.",
  "homepage_url": "https://alt-text-q6lg8jonb-ersil.vercel.app",
  "minimum_chrome_version": "114",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["activeTab", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "SEO Alt Text Assistant",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    },
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
